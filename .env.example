# Runtime mode:
# - desktop_local: default packaged/local desktop mode.
# - server_mode: HTTP/server mode. Set ACCESS_TOKEN and keep desktop-only operations disabled.
RUN_MODE=desktop_local

# Optional bearer token for regular HTTP API access.
ACCESS_TOKEN=

# Electron generates this automatically for desktop launches.
# Set only for controlled local debugging.
NOVA_DESKTOP_TOKEN=

# High-risk local actions have moved to Electron IPC and return HTTP 410 by default.
# Set to true only for temporary compatibility testing of legacy desktop-token HTTP calls.
NOVA_ENABLE_LEGACY_SYSTEM_HTTP=false

# Remote AI TLS verification is enabled by default.
# Set to true only for local debugging with a trusted interception proxy.
ALLOW_INSECURE_TLS=false

HOST=127.0.0.1
PORT=8765
